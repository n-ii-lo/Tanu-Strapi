# Strapi Configuration
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=1337
APP_KEYS=your_app_keys_here

# Admin Panel
ADMIN_JWT_SECRET=your_very_long_random_string_here
API_TOKEN_SALT=your_another_very_long_random_string_here
TRANSFER_TOKEN_SALT=yet_another_very_long_random_string_here
PUBLIC_ADMIN_URL=/admin

# For Production (Strapi Cloud / PostgreSQL)
# DATABASE_CLIENT=postgres
# DATABASE_HOST=your-db-host
# DATABASE_PORT=5432
# DATABASE_NAME=tanu_strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=your_db_password
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# For Local Development (SQLite)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Seed Data
# Set to 'true' to populate initial categories and products
SEED_DATA=true

# Strapi Cloud
# STRAPI_CLOUD_TOKEN=scm_your_token_here
# STRAPI_CLOUD_PROJECT_ID=your_project_id
