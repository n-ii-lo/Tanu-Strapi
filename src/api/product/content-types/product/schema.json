{
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Ice cream products with name, price, image, description and category"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "required": true
    },
    "description": {
      "type": "text",
      "required": false
    },
    "price": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "image": {
      "type": "media",
      "required": false,
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products",
      "required": true
    },
    "available": {
      "type": "boolean",
      "required": false,
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
